# ╔══════════════════════════════════════════════════════════════╗
# ║  FLOW AI — Environment Variables                            ║
# ║  Copy to .env.local and fill in your values                 ║
# ╚══════════════════════════════════════════════════════════════╝

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://gwdf.pro
# For local dev: http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...

# ── Anthropic (Claude for hashtags + music matching) ──────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Google / YouTube ──────────────────────────────────────────
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
YOUTUBE_API_KEY=AIza...

# ── Meta (Instagram + Facebook) ───────────────────────────────
META_APP_ID=123456789
META_APP_SECRET=abc123...

# ── X / Twitter ───────────────────────────────────────────────
TWITTER_CLIENT_ID=abc123
TWITTER_CLIENT_SECRET=xyz789

# ── RiteKit (Optional — trending hashtag data) ────────────────
RITEKIT_API_KEY=

# ── AssemblyAI (Optional — higher quality captions) ───────────
ASSEMBLYAI_API_KEY=
